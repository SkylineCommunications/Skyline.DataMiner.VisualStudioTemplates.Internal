{
  "$schema": "http://json.schemastore.org/template",
  "author": "Skyline Communications",
  "classifications": [
    "DataMiner",
    "SLNet",
    "RepositoryApi"
  ],
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "identity": "Skyline.DataMiner.SLNet.RepositoryApi",
  "name": "DataMiner SLNet RepositoryApi",
  "shortName": "dataminer-slnet-repositoryapi",
  "sourceName": "$SCRIPTNAME$",
  "symbols": {
    "TableName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "NewTable",
      "replaces": "$TABLENAME$",
      "fileRename":"$TABLENAME$",
      "description": "The table name."
    }
  },
  "sources": [
    {
      "exclude": [
        "./[Content_Types].xml",
        "src/.vs/**",
        ".template_config/**",
        "[Content_Types].xml",
        "_rels/**",
        "*.nuspec",
        "*.nupkg"
      ]
    }]
}